{
  "lexicon": 1,
  "id": "com.etzhayyim.kanayama.intakeRecord",
  "description": "UBC bale intake QA record (L1). Weighing + Cl residue + moisture + magnetic + non-Al impurity detection. Per ADR-2605252400 L1.",
  "defs": {
    "main": {
      "type": "record",
      "record": {
        "type": "object",
        "properties": {
          "lotId": {"type": "string"},
          "baleWeightKg": {"type": "number"},
          "chlorideResidualPpm": {"type": "number"},
          "moisturePct": {"type": "number"},
          "magneticImpurityPct": {"type": "number"},
          "nonAlNonMagneticImpurityPct": {"type": "number"},
          "accept": {"type": "boolean"},
          "recordedAt": {"type": "string", "format": "datetime"}
        },
        "required": ["lotId", "baleWeightKg", "accept"]
      }
    }
  }
}

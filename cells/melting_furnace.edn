;; kanayama 金 — melting_furnace cell (langgraph, WASM runtime)
;; L3, joseph node
{:cell/id "melting_furnace"
 :cell/glyph "金"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_melting_furnace"
 :cell/doc "Twin-chamber Al furnace ~720°C, N₂ / Cl₂ degas, salt-flux refining, 3xxx / 5xxx alloy adjust."
 :cell/state-graph
 {:nodes [:melt :degas :refine :alloy-adjust]
  :entry :melt
  :edges [[:melt :degas] [:degas :refine] [:refine :alloy-adjust] [:alloy-adjust :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G5" "G6" "G4"]
 :cell/kotoba
 {:reads [:decoatingAttestation/id :decoatingAttestation/shredded-weight]
  :writes [:meltingAttestation/id :meltingAttestation/decoatingAttestationId :meltingAttestation/temperature :meltingAttestation/alloy :meltingAttestation/melt-weight]}}

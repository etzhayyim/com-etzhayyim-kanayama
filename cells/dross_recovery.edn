;; kanayama 金 — dross_recovery cell (langgraph, WASM runtime)
;; cross-cutting, joseph node
{:cell/id "dross_recovery"
 :cell/glyph "金"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_dross_recovery"
 :cell/doc "Salt-cake processing → K-salt + secondary Al; never standalone disposal (G14 + §2(g))."
 :cell/state-graph
 {:nodes [:process-dross :separate-salt-metal]
  :entry :process-dross
  :edges [[:process-dross :separate-salt-metal] [:separate-salt-metal :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G5" "G6" "G14"]
 :cell/kotoba
 {:reads [:meltingAttestation/id]
  :writes [:drossRecoveryRecord/id :drossRecoveryRecord/meltingAttestationId :drossRecoveryRecord/secondary-al-weight :drossRecoveryRecord/salt-cake-weight]}}

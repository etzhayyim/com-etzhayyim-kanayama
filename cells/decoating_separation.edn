;; kanayama 金 — decoating_separation cell (langgraph, WASM runtime)
;; L2, zebulun node
{:cell/id "decoating_separation"
 :cell/glyph "金"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_decoating_separation"
 :cell/doc "De-coating + shred + sort: ~500°C rotary de-coater, rotary shredder, magnetic + eddy-current separation."
 :cell/state-graph
 {:nodes [:decoat :shred :separate]
  :entry :decoat
  :edges [[:decoat :shred] [:shred :separate] [:separate :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G5" "G6"]
 :cell/kotoba
 {:reads [:intakeRecord/id :intakeRecord/weight]
  :writes [:decoatingAttestation/id :decoatingAttestation/intakeRecordId :decoatingAttestation/process-params :decoatingAttestation/shredded-weight]}}

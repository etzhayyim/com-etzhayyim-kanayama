;; kanayama 金 — kotoba EAVT schema
;; ADR-2605252400 · migration plan Phase 3
;; Circular metallurgy (UBC recycling) over kotoba Datoms: intake QA, decoating,
;; melting, casting, rolling, final QC, emissions audit, and mass-balance settlement.
;; All state is kotoba Datoms — replaces the legacy kotoba-datomic + RisingWave path (G6).

[;; ───────────────────────────── :intake/* — L1 UBC bale QA ─────────────────────────────
 {:db/ident :intake/id
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/unique :db.unique/identity
  :db/doc "L1 intake record ID"}
 {:db/ident :intake/bale-weight
  :db/valueType :db.type/double
  :db/cardinality :db.cardinality/one
  :db/doc "kg, gross UBC bale weight"}
 {:db/ident :intake/cl-residue-pct
  :db/valueType :db.type/double
  :db/cardinality :db.cardinality/one
  :db/doc "Cl residue % on UBC surface"}
 {:db/ident :intake/moisture-pct
  :db/valueType :db.type/double
  :db/cardinality :db.cardinality/one
  :db/doc "moisture % by weight"}
 {:db/ident :intake/magnetic-impurity-ppm
  :db/valueType :db.type/long
  :db/cardinality :db.cardinality/one
  :db/doc "Fe contamination ppm"}
 {:db/ident :intake/qa-passed
  :db/valueType :db.type/boolean
  :db/cardinality :db.cardinality/one
  :db/doc "passes L1 intake quality thresholds (G3)"}

 ;; ───────────────────────────── :decoating/* — L2 de-coating + sort ─────────────────────────────
 {:db/ident :decoating/id
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/unique :db.unique/identity}
 {:db/ident :decoating/intake
  :db/valueType :db.type/ref
  :db/cardinality :db.cardinality/one
  :db/doc "ref → :intake record"}
 {:db/ident :decoating/input-mass
  :db/valueType :db.type/double
  :db/cardinality :db.cardinality/one
  :db/doc "kg, de-coating input mass"}
 {:db/ident :decoating/coating-mass-loss
  :db/valueType :db.type/double
  :db/cardinality :db.cardinality/one
  :db/doc "kg, burnt-off coating from ~500°C rotary decoater"}
 {:db/ident :decoating/magnetic-sort
  :db/valueType :db.type/double
  :db/cardinality :db.cardinality/one
  :db/doc "kg, Fe fraction separated"}
 {:db/ident :decoating/output-mass
  :db/valueType :db.type/double
  :db/cardinality :db.cardinality/one
  :db/doc "kg, shredded Al ready for melt"}
 {:db/ident :decoating/ipfs-photo
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/doc "IPFS CID of batch photo (G3)"}

 ;; ───────────────────────────── :melting/* — L3 twin-chamber melt + alloy ─────────────────────────────
 {:db/ident :melting/id
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/unique :db.unique/identity}
 {:db/ident :melting/decoating

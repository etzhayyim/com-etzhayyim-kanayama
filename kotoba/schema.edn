 {:db/ident :melting/dross-collected
  :db/valueType :db.type/double
  :db/cardinality :db.cardinality/one
  :db/doc "kg, dross stream for dross_recovery cell"}
 {:db/ident :melting/witness-sigs
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/many
  :db/doc "DID signatures of ≥2 robot witnesses (Yokin pour, Kamado tend; G4)"}


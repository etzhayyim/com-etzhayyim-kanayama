  :db/cardinality :db.cardinality/one
  :db/doc "ref → :decoating record"}
 {:db/ident :melting/input-mass
  :db/valueType :db.type/double
  :db/cardinality :db.cardinality/one
  :db/doc "kg, decoated shred input"}
 {:db/ident :melting/melt-temp
  :db/valueType :db.type/double
  :db/cardinality :db.cardinality/one
  :db/doc "°C, furnace chamber temp (~720°C for Al)"}
 {:db/ident :melting/degas-method
  :db/valueType :db.type/keyword
  :db/cardinality :db.cardinality/one
  :db/doc ":n2 | :cl2 (degas method for G2 air emissions)"}
 {:db/ident :melting/output-mass
  :db/valueType :db.type/double
  :db/cardinality :db.cardinality/one
  :db/doc "kg, liquid metal cast-ready"}
 {:db/ident :melting/alloy-designation
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one

 {:db/ident :quality/weight-ok
  :db/valueType :db.type/boolean
  :db/cardinality :db.cardinality/one
  :db/doc "weight ±2% pass"}
 {:db/ident :quality/visual-defect-pct
  :db/valueType :db.type/double
  :db/cardinality :db.cardinality/one
  :db/doc "% defect area (<0.5% pass per G12)"}
 {:db/ident :quality/result
  :db/valueType :db.type/keyword
  :db/cardinality :db.cardinality/one
  :db/doc ":pass | :fail | :rework"}
 {:db/ident :quality/inspector-did
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/doc "robot inspector DID (Migaki; no-server-key G15)"}

 ;; ───────────────────────────── :emissions/* — cross-cutting air emissions audit ─────────────────────────────
 {:db/ident :emissions/id
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/unique :db.unique/identity}
 {:db/ident :emissions/pfc-level
  :db/valueType :db.type/double
  :db/cardinality :db.cardinality/one
  :db/doc "mg/m³, perfluorinated compounds"}
 {:db/ident :emissions/so2-level
  :db/valueType :db.type/double
  :db/cardinality :db.cardinality/one
  :db/doc "mg/m³, sulfur dioxide"}
 {:db/ident :emissions/passed-audit
  :db/valueType :db.type/boolean
  :db/cardinality :db.cardinality/one
  :db/doc "all levels ≤ regulatory limit (EU IED + 大気汚染防止法; G8)"}

 ;; ───────────────────────────── :settlement/* — USDC + TitheRouter intent (NOT executed; G7/G11) ─────────────────────────────
 {:db/ident :settlement/id
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/unique :db.unique/identity
  :db/doc "settlement intent ID (mass-balance batch basis)"}
 {:db/ident :settlement/batch-id
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/doc "aggregated batch ID (intakeRecord..silenRecyclingReview)"}
 {:db/ident :settlement/gross-minor
  :db/valueType :db.type/long
  :db/cardinality :db.cardinality/one
  :db/doc "USDC minor (6-dp) gross batch settlement value"}
 {:db/ident :settlement/tithe-minor
  :db/valueType :db.type/long
  :db/cardinality :db.cardinality/one
  :db/doc "10% TitheRouter auto-split → Public Fund (G7)"}
 {:db/ident :settlement/operator-payout-minor
  :db/valueType :db.type/long
  :db/cardinality :db.cardinality/one
  :db/doc "net to operator (gross − tithe), USDC minor"}
 {:db/ident :settlement/state
  :db/valueType :db.type/keyword
  :db/cardinality :db.cardinality/one
  :db/doc ":intent (computed, NOT broadcast) | :executed (operator-signed + broadcast, G11/G15). R0 stops at :intent"}
 {:db/ident :settlement/buyer-sig-ref
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/doc "operator passkey/smart-account signature ref; platform holds no key (G15). absent ⇒ stays :intent"}

 ;; ───────────────────────────── :sbt/* — Adherent SBT eligibility (§3 / G2) ─────────────────────────────
 {:db/ident :sbt/holder-did
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/unique :db.unique/identity
  :db/doc "DID of an Adherent SBT holder (operator/member)"}
 {:db/ident :sbt/active
  :db/valueType :db.type/boolean
  :db/cardinality :db.cardinality/one
  :db/doc "active Adherent SBT? required for internal SBT↔SBT settlement (§3 / G2)"}]

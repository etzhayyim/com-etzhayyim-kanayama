[{:db/id -1, :meltingAttestation/lexicon 1, :meltingAttestation/id "com.etzhayyim.kanayama.meltingAttestation", :meltingAttestation/defs "{:main {:type \"record\", :key \"tid\", :record {:type \"object\", :required [\"attestationId\" \"decoatingId\" \"meltTemp\"], :properties {:emissionRecordId {:type \"string\", :description \"→ airEmissionsAuditRecord for this pour\"}, :decoatingId {:type \"string\", :description \"→ decoatingAttestation\"}, :attestationId {:type \"string\"}, :witnessSigs {:type \"array\", :items {:type \"string\"}, :description \"DID signatures of >=2 robots (G4)\"}, :degasMethod {:type \"string\", :description \"N2 / Cl2 degas (G2 air emissions)\"}, :inputMass {:type \"number\", :description \"kg, decoated shred input\"}, :saltFluxMass {:type \"number\", :description \"kg, refining flux added\"}, :alloyDesignation {:type \"string\", :description \"3xxx / 5xxx series (alloy code)\"}, :meltTemp {:type \"number\", :description \"°C, furnace chamber temp (~720°C Al)\"}, :timestamp {:type \"string\", :format \"datetime\"}, :drossCollected {:type \"number\", :description \"kg, dross stream (→ dross_recovery)\"}, :outputMass {:type \"number\", :description \"kg, liquid metal cast-ready\"}}}}}"}]
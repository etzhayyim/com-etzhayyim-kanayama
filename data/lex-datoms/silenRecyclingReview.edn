[{:db/id -1, :silenRecyclingReview/lexicon 1, :silenRecyclingReview/id "com.etzhayyim.kanayama.silenRecyclingReview", :silenRecyclingReview/defs "{:main {:type \"record\", :key \"tid\", :record {:type \"object\", :required [\"reviewId\" \"batchId\" \"councilLv\"], :properties {:recoveryRate {:type \"number\", :description \"%, recycled Al / input (≥95% target G12)\"}, :wasteTracking {:type \"string\", :description \"IPFS lot-track ID for dross/emissions (G14)\"}, :reviewId {:type \"string\"}, :renewableEnergy {:type \"boolean\", :description \"all energy from renewable + grid-balanced (G13)\"}, :massBalanceClosure {:type \"number\", :description \"%, input_mass = output_metal + dross + emission (≥98% G2)\"}, :approved {:type \"boolean\", :description \"batch approved by Council quorum\"}, :attestationNotes {:type \"string\"}, :councilLv {:type \"integer\", :description \"Council attestation level (Lv6+ for R0 activation)\"}, :batchId {:type \"string\", :description \"material batch under review (aggregates intakeRecord..coilQualificationRecord)\"}, :energyIntensity {:type \"number\", :description \"kWh/kg, total energy use (≤6 kWh/kg Wave 1 Al)\"}, :timestamp {:type \"string\", :format \"datetime\"}, :councilSignatures {:type \"array\", :items {:type \"string\"}, :description \"≥5-of-7 Safe member DIDs\"}}}}}"}]